generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  master
  dono
  gerencia
  mecanico
}

enum WorkshopType {
  carros
  motos
  mista
  estetica
}

enum AgendaStatus {
  pendente
  aprovado
  recusado
}

enum SponsorshipTier {
  none
  bronze
  prata
  ouro
  diamante
}

enum AnnouncementPlacement {
  home_topo
  home_meio
  oficinas_topo
  site_geral
}

enum AnnouncementStyle {
  info
  promo
  alerta
}

enum ServiceOrderStatus {
  pendente
  em_andamento
  concluido
  cancelado
}

enum MechanicKind {
  fictional
  platform
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         UserRole
  workshopId   String?
  workshop     Workshop? @relation(fields: [workshopId], references: [id], onDelete: SetNull)
  sessions     Session[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

model Workshop {
  id              String           @id
  name            String
  slug            String           @unique
  type            WorkshopType
  description     String
  tagline         String?
  address         String
  city            String
  state           String
  phone           String
  whatsapp        String
  email           String
  rating          Float            @default(0)
  reviewCount     Int              @default(0)
  services        Json
  openingHours    String
  image           String
  coverImage      String?
  gallery         Json?
  specialties     Json
  hasAgenda       Boolean          @default(true)
  paymentMethods  Json
  catalog         Json
  mechanicRanking Json?
  users           User[]
  reviews         Review[]
  agendaRequests  AgendaRequest[]
  sponsorship     Sponsorship?
  crmClients      CrmClient[]
  crmVehicles     CrmVehicle[]
  serviceOrders   CrmServiceOrder[]
  fictionalMechanics FictionalMechanic[]
  suppliers       SupplierContact[]
  catalogOverride Json?
  slogan          String?
  profileVideos   Json?
  profileHighlights Json?
  businessOpportunities Json?
  catalogItems    CatalogItem[]
  budgets         WorkshopBudget[]
  serviceNotes    ServiceNote[]
  stockItems      StockItem[]
  employeeCompensations EmployeeCompensation[]
  salaryAdvances  SalaryAdvance[]
  managerPermissions ManagerPermissionGrant[]
  financialEntries FinancialEntry[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Review {
  id           String   @id
  workshopId   String
  workshop     Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  cpf          String
  clientName   String
  stars        Int
  comment      String
  serviceLabel String
  removed      Boolean  @default(false)
  createdAt    DateTime
  updatedAt    DateTime

  @@unique([workshopId, cpf])
  @@index([workshopId])
}

model CrmClient {
  id                String            @id
  workshopId        String
  workshop          Workshop          @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  cpf               String
  name              String
  phone             String            @default("")
  birthDate         DateTime?
  completedServices Json
  vehicles          CrmVehicle[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@unique([workshopId, cpf])
  @@index([workshopId])
}

model CrmVehicle {
  id                String    @id
  workshopId        String
  workshop          Workshop  @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  clientId          String?
  client            CrmClient? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  plate             String
  model             String
  completedServices Json      @default("[]")

  @@unique([workshopId, plate])
  @@index([workshopId])
  @@index([clientId])
}

model CrmServiceOrder {
  id           String             @id
  workshopId   String
  workshop     Workshop           @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  clientId     String?
  vehicleId    String?
  clientName   String             @default("")
  clientCpf    String             @default("")
  vehicle      String
  vehiclePlate String?
  service      String
  status       ServiceOrderStatus @default(pendente)
  date         String
  value        Float
  lineItems    Json?
  paymentMethods Json?
  mechanicId   String?
  mechanicKind MechanicKind?
  mechanicName String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([workshopId])
  @@index([workshopId, status])
  @@index([vehicleId])
}

model FictionalMechanic {
  id         String   @id
  workshopId String
  workshop   Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  name       String
  specialty  String?
  notes      String?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([workshopId])
}

model SupplierContact {
  id         String   @id
  workshopId String
  workshop   Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  name       String
  phone      String
  notes      String?
  createdAt  DateTime @default(now())

  @@index([workshopId])
}

model AgendaRequest {
  id            String       @id
  workshopId    String
  workshop      Workshop     @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  clientName    String
  clientPhone   String
  vehicle       String?
  preferredDate String
  preferredTime String
  service       String
  status        AgendaStatus @default(pendente)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([workshopId, status])
}

model Sponsorship {
  id           String          @id @default(cuid())
  workshopId   String          @unique
  workshop     Workshop        @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  tier         SponsorshipTier
  monthlyValue Float?
  notes        String?
  updatedAt    DateTime        @updatedAt
}

model SiteAnnouncement {
  id        String                @id
  title     String
  message   String
  linkUrl   String?
  linkLabel String?
  placement AnnouncementPlacement
  style     AnnouncementStyle
  active    Boolean               @default(true)
  createdAt DateTime
}

enum CatalogItemKind {
  servico
  peca
}

enum BudgetStatus {
  rascunho
  aguardando_aprovacao
  aprovado
  rejeitado
  convertido
}

enum ServiceNoteStatus {
  rascunho
  emitida
  paga
}

enum FinancialEntryKind {
  receber
  pagar
}

model CatalogItem {
  id            String          @id @default(cuid())
  workshopId    String
  workshop      Workshop        @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  kind          CatalogItemKind
  name          String
  description   String?
  unitPrice     Float
  publicVisible Boolean         @default(true)
  active        Boolean         @default(true)
  stockItem     StockItem?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([workshopId, kind])
  @@index([workshopId, publicVisible])
}

model StockItem {
  id            String       @id @default(cuid())
  workshopId    String
  workshop      Workshop     @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  catalogItemId String?      @unique
  catalogItem   CatalogItem? @relation(fields: [catalogItemId], references: [id], onDelete: SetNull)
  name          String
  sku           String?
  quantity      Float        @default(0)
  minQuantity   Float        @default(0)
  unitPrice     Float?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([workshopId])
}

model WorkshopBudget {
  id             String       @id @default(cuid())
  workshopId     String
  workshop       Workshop     @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  vehicleId      String
  clientId       String?
  status         BudgetStatus @default(rascunho)
  lineItems      Json
  paymentMethods Json?
  subtotal       Float        @default(0)
  total          Float        @default(0)
  notes          String?
  mechanicId     String?
  mechanicKind   MechanicKind?
  mechanicName   String?
  createdById    String?
  approvedAt     DateTime?
  serviceNoteId  String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([workshopId, status])
  @@index([vehicleId])
}

model ServiceNote {
  id               String            @id @default(cuid())
  workshopId       String
  workshop         Workshop          @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  vehicleId        String
  clientId         String?
  budgetId         String?
  status           ServiceNoteStatus @default(emitida)
  lineItems        Json
  paymentMethods   Json?
  subtotal         Float             @default(0)
  total            Float             @default(0)
  mechanicId       String?
  mechanicKind     MechanicKind?
  mechanicName     String?
  commissionRate   Float?
  commissionAmount Float?
  commissionPaid   Boolean           @default(false)
  commissionPaidAt DateTime?
  stockDeducted    Boolean           @default(false)
  issuedAt         DateTime          @default(now())
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([workshopId])
  @@index([workshopId, mechanicId])
  @@index([budgetId])
}

model EmployeeCompensation {
  id                  String   @id @default(cuid())
  workshopId          String
  workshop            Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  userId              String?
  fictionalMechanicId String?
  salary              Float    @default(0)
  commissionRate      Float    @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([workshopId, userId])
  @@unique([workshopId, fictionalMechanicId])
  @@index([workshopId])
}

model SalaryAdvance {
  id                  String   @id @default(cuid())
  workshopId          String
  workshop            Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  userId              String?
  fictionalMechanicId String?
  amount              Float
  date                DateTime
  notes               String?
  createdAt           DateTime @default(now())

  @@index([workshopId])
}

model ManagerPermissionGrant {
  id         String   @id @default(cuid())
  workshopId String
  workshop   Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  userId     String
  permission String
  granted    Boolean  @default(true)

  @@unique([userId, permission])
  @@index([workshopId])
}

model FinancialEntry {
  id                String             @id @default(cuid())
  workshopId        String
  workshop          Workshop           @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  kind              FinancialEntryKind
  name              String
  amount            Float
  dueAt             DateTime?
  paid              Boolean            @default(false)
  paidAt            DateTime?
  serviceNoteId     String?
  reminderDayBefore Boolean            @default(true)
  reminderSameDay   Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([workshopId, kind])
  @@index([workshopId, dueAt])
}
